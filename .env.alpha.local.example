# Web public env only. These may be exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# API/worker server-only env. Never expose these to Vercel client bundles.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
MYGM_CREDENTIAL_KEY_V1=replace-with-32-byte-base64-development-key
MYGM_CREDENTIAL_KEY_ID=local-dev-1
MYGM_ALLOWED_ORIGINS=http://127.0.0.1:3000
MYGM_IMPORT_POLL_INTERVAL_SECONDS=5

# Never store real ESPN cookies in committed env examples.
