# Local fixture and harness defaults. Copy to `.env.local` if you need overrides.
MYGM_FIXTURE_ZIP=espn_league_<id>_export.zip
MYGM_FIXTURE_ROOT=tests/fixtures/espn/league_<id>
API_BASE=http://127.0.0.1:8000
WEB_BASE=http://127.0.0.1:3000

# Supabase local/dev values are filled by the owning schema/API tasks.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Do not put real ESPN cookies, service role keys, or credential encryption keys in this file.
